# =============================================================================
# Smart Collaboration SaaS Platform — .gitignore
# =============================================================================

# Dependencies — all levels (services/*, frontend)
node_modules/
**/node_modules/
.pnp
.pnp.js

# Environment variables — NEVER commit secrets
.env
.env.*
!.env.example

# Build outputs
dist/
build/
.next/
out/
**/dist/
**/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino*.log

# OS
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# Docker volumes (local data)
pgdata/
redisdata/

# Coverage reports
coverage/
**/coverage/
.nyc_output/
*.lcov

# RSA / TLS keys — never commit private keys or certificates
*.pem
*.key
*.crt
*.p12
*.pfx

# Docker Compose personal overrides (developer-local settings)
docker-compose.override.yml

# Local environment overrides
*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vite / Webpack cache
.vite/
.cache/
**/.cache/

# Jest cache
.jest-cache/
jest_html_reporters.html

# TypeScript incremental compilation cache
*.tsbuildinfo
tsconfig.tsbuildinfo
