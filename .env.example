# =============================================================================
# Smart Collaboration SaaS Platform — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All secrets must be injected via environment variables at deploy time.
# =============================================================================


# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000


# -----------------------------------------------------------------------------
# JWT — RS256 (asymmetric keys)
# -----------------------------------------------------------------------------
# Generate a 2048-bit RSA key pair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   # Then base64-encode each file (single line, no newlines):
#   base64 -w 0 private.pem   # → paste as JWT_PRIVATE_KEY
#   base64 -w 0 public.pem    # → paste as JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d


# -----------------------------------------------------------------------------
# Encryption — AES-256-GCM (for OAuth tokens at rest)
# -----------------------------------------------------------------------------
# Generate a 32-byte random hex key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@postgres:5432/smartcollab
# Used in test environment only
DATABASE_URL_TEST=postgresql://user:pass@localhost:5432/smartcollab_test

POSTGRES_DB=smartcollab
POSTGRES_USER=user
POSTGRES_PASSWORD=pass


# -----------------------------------------------------------------------------
# Cache & Pub/Sub — Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379


# -----------------------------------------------------------------------------
# Internal Service URLs (Docker internal network)
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://auth-service:3001
TASK_SERVICE_URL=http://task-service:3002
INTEGRATION_SERVICE_URL=http://integration-service:3003
AI_SERVICE_URL=http://ai-service:3004


# -----------------------------------------------------------------------------
# AI — Providers
# -----------------------------------------------------------------------------
# Which provider to use: 'openai' | 'huggingface'
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# HuggingFace (fallback / open-source models)
HUGGINGFACE_API_KEY=


# -----------------------------------------------------------------------------
# OAuth2 — GitHub Integration (webhook + API access)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# OAuth2 login with GitHub (user authentication)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth/github/callback


# -----------------------------------------------------------------------------
# OAuth2 — Google Integration (Google Calendar connector)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 login with Google (user authentication)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth/google/callback


# -----------------------------------------------------------------------------
# Slack Integration
# -----------------------------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=


# -----------------------------------------------------------------------------
# Trello Integration
# -----------------------------------------------------------------------------
TRELLO_API_KEY=
TRELLO_TOKEN=
