# =============================================================================
# Auth Service — Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@localhost:5432/smartcollab

# Set to true to log all SQL queries (development only)
KNEX_DEBUG=false

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# JWT (RS256)
# Generate keys with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   # Then base64-encode each:
#   base64 -w 0 private.pem
#   base64 -w 0 public.pem
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY=<base64-encoded-RS256-private-key-PEM>
JWT_PUBLIC_KEY=<base64-encoded-RS256-public-key-PEM>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---------------------------------------------------------------------------
# Encryption (AES-256-GCM for OAuth tokens stored in DB)
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=<64-character-hex-string>

# ---------------------------------------------------------------------------
# GitHub OAuth
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:3001/api/v1/auth/oauth/github/callback
# ---------------------------------------------------------------------------
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/github/callback

# ---------------------------------------------------------------------------
# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3001/api/v1/auth/oauth/google/callback
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/google/callback
