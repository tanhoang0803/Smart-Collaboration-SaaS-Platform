      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(http_requests_total{job=\"api-gateway\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"api-gateway\"}[5m]) * 100",
          "legendFormat": "api-gateway error %",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(http_requests_total{job=\"auth-service\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"auth-service\"}[5m]) * 100",
          "legendFormat": "auth-service error %",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(http_requests_total{job=\"task-service\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"task-service\"}[5m]) * 100",
          "legendFormat": "task-service error %",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(http_requests_total{job=\"integration-service\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"integration-service\"}[5m]) * 100",
          "legendFormat": "integration-service error %",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(http_requests_total{job=\"ai-service\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"ai-service\"}[5m]) * 100",
          "legendFormat": "ai-service error %",
          "refId": "E"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "Row 5 — AI Service Deep Dive",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
